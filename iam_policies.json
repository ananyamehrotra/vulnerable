{
  "IAMPolicies": [
    {
      "PolicyName": "DevTeamPolicy",
      "Description": "Policy for dev team - started broad, never narrowed down",
      "PolicyDocument": {
        "Version": "2012-10-17",
        "Statement": [
          {
            "Sid": "FullAccess",
            "Effect": "Allow",
            "Action": "*",
            "Resource": "*",
            "Condition": {}
          }
        ]
      }
    },
    {
      "PolicyName": "S3ReadPolicy",
      "Description": "Supposed to be read-only S3, but...",
      "PolicyDocument": {
        "Version": "2012-10-17",
        "Statement": [
          {
            "Sid": "S3Everything",
            "Effect": "Allow",
            "Action": [
              "s3:*"
            ],
            "Resource": "*"
          },
          {
            "Sid": "AlsoEC2ForSomeReason",
            "Effect": "Allow",
            "Action": [
              "ec2:*",
              "iam:*",
              "lambda:*"
            ],
            "Resource": "*"
          }
        ]
      }
    },
    {
      "PolicyName": "LambdaExecutionRole",
      "Description": "Lambda needs some permissions",
      "PolicyDocument": {
        "Version": "2012-10-17",
        "Statement": [
          {
            "Effect": "Allow",
            "Action": [
              "logs:*",
              "s3:*",
              "dynamodb:*",
              "secretsmanager:*",
              "ssm:*",
              "kms:*",
              "iam:PassRole",
              "iam:CreateRole",
              "iam:AttachRolePolicy"
            ],
            "Resource": "*"
          }
        ]
      }
    },
    {
      "PolicyName": "CrossAccountAccess",
      "Description": "Allow cross-account - who set this up??",
      "PolicyDocument": {
        "Version": "2012-10-17",
        "Statement": [
          {
            "Effect": "Allow",
            "Action": "sts:AssumeRole",
            "Principal": {
              "AWS": "*"
            },
            "Resource": "*"
          }
        ]
      }
    }
  ],
  "InlineRolePolicies": [
    {
      "RoleName": "prod-app-role",
      "PolicyName": "inline-everything",
      "PolicyDocument": {
        "Version": "2012-10-17",
        "Statement": [
          {
            "Effect": "Allow",
            "Action": "*",
            "Resource": "*",
            "Condition": {
              "StringEquals": {
                "aws:RequestedRegion": "us-east-1"
              }
            }
          }
        ]
      }
    }
  ]
}
